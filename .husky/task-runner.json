{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "dotnet-restore",
         "group": "pre-commit",
         "command": "dotnet",
         "args": ["restore"],
         "include": ["**/*.cs", "**/*.vb"]
      },
      {
         "name": "dotnet-format",
         "group": "pre-commit",
         "command": "dotnet",
         "args": ["format", "--no-restore"],
         "include": ["**/*.cs", "**/*.vb"]
      },
      {
         "name": "warning-check",
         "command": "dotnet",
         "group": "pre-push",
         "args": ["build", "." /* agar buni qo'shsak warning larni to'g'irlash kerak bo'ladi "/warnaserror"*/],
         "include": ["**/*.cs", "**/*.vb"]
      }
   ]
}